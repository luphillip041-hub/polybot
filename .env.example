# =============================================================================
# Polymarket Copybot — Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env   # then edit .env
# All settings are optional — defaults work for paper-only / read-only operation.
# =============================================================================

# --- Auth (required for live trading only) ---
# PRIVATE_KEY=0x...
# FUNDER_ADDRESS=0x...
# SIGNATURE_TYPE=0          # 0=EOA, 1=Magic/email, 2=browser proxy

# --- CLOB / API ---
# CLOB_HOST=https://clob.polymarket.com
# DATA_API=https://data-api.polymarket.com
# GAMMA_API=https://gamma-api.polymarket.com
# POLYGON_RPC_URL=https://polygon-rpc.com   # for on-chain resolution reads

# --- Copy targets ---
# TARGET_WALLETS=0xabc...,0xdef...
# AUTO_SELECT=false
# LB_WINDOW=MONTH
# LB_TOP_N=10
# LB_MIN_PNL=5000
# LB_MIN_VOLUME=20000
# LB_MIN_RECENT_TRADES=3
# ACTIVE_WINDOW_DAYS=3
# RESELECT_INTERVAL_SEC=21600

# --- Sizing / risk ---
# COPY_MODE=fixed           # fixed | proportional
# FIXED_SIZE_USD=5.0
# SIZE_PCT=0.05
# MAX_POSITION_USD=25.0
# MAX_DAILY_SPEND_USD=100.0
# MIN_ORDER_USD=1.0
# MIN_PRICE=0.03
# MAX_PRICE=0.97
# COPY_SELLS=true

# --- Loop ---
# POLL_INTERVAL_SEC=15
# DRY_RUN=true

# --- Paper trading ---
# PAPER_ORDER_SIZE_USD=25.0
# STALE_FILL_SECONDS=480
# MAX_OPEN_POSITIONS=150
# PAPER_POLL_INTERVAL_SEC=3

# --- Book archive ---
# TOP_N_MARKETS=10
# SNAPSHOT_INTERVAL_SEC=30
# WALLET_POLL_INTERVAL_SEC=15
# RETENTION_DAYS=45
# MAX_TOKENS=800
# WALLET_LIMIT_FROM_SCORES=25

# --- Webhooks ---
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...

# --- Dashboard / status ---
# STATUS_API_PORT=8710
# DASHBOARD_PORT=8080

# --- Paths (defaults to runs/ under project root) ---
# STATE_FILE=state.json
# JOURNAL_FILE=trades.jsonl
# CONTROL_FILE=control.json
# PAPER_DIR=runs/paper
# ARCHIVE_DIR=runs/book_archive
# ARCHIVE_CONFIG=archive_config.json
